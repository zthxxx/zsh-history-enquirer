# e2e alpine image — musl libc counterpart to Dockerfile.debian.
# `ncurses` is kept because zsh links against it at runtime under
# alpine. The Go-native harness drives the pty in-process so no
# expect/tcl is needed.
FROM alpine:3.20

RUN apk add --no-cache zsh ca-certificates ncurses

ENV TERM=xterm-256color

RUN adduser -D -s /bin/zsh tester
WORKDIR /home/tester

ENTRYPOINT ["/runner.sh"]
