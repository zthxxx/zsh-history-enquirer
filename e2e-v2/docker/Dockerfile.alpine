# e2e-v2 alpine image — musl libc counterpart to Dockerfile.debian.
# `ncurses` is kept because zsh links against it at runtime under
# alpine (same as e2e/alpine/Dockerfile). `expect` is omitted because
# the v2 harness drives the pty in Go.
FROM alpine:3.20

RUN apk add --no-cache zsh ca-certificates ncurses

ENV TERM=xterm-256color

RUN adduser -D -s /bin/zsh tester
WORKDIR /home/tester

ENTRYPOINT ["/runner.sh"]
