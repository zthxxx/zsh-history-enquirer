# Shared VHS header — paste into every tape's top section.
# Not a tape itself (no Output); the leading underscore tells the
# Taskfile glob to skip it.

Set Shell zsh
Set FontSize 14
Set FontFamily "JetBrainsMono Nerd Font"
Set Width 960
Set Height 540
Set Theme "Dracula"
Set TypingSpeed 75ms
Set PlaybackSpeed 1.0
